recur(-1)  [a=[], v=[[]]]
│
└─→ recur(0)  [add 1 to a → a=[1], v+=[[1]]]
    │
    ├─→ FIRST recur(1)  [add 2 to a → a=[1,2], v+=[[1,2]]]
    │   │
    │   ├─→ FIRST recur(2)  [add 3 to a → a=[1,2,3], v+=[[1,2,3]]]
    │   │   │
    │   │   ├─→ FIRST recur(3)  [BASE: i>=n, pop → a=[1,2]]
    │   │   │   
    │   │   └─→ SECOND recur(3)  [BASE: i>=n, pop → a=[1]]
    │   │
    │   └─→ SECOND recur(2)  [add 3 to a → a=[1,3], v+=[[1,3]]]
    │       │
    │       ├─→ FIRST recur(3)  [BASE: i>=n, pop → a=[1]]
    │       │
    │       └─→ SECOND recur(3)  [BASE: i>=n, pop → a=[]]
    │
    └─→ SECOND recur(1)  [add 2 to a → a=[2], v+=[[2]]]
        │
        ├─→ FIRST recur(2)  [add 3 to a → a=[2,3], v+=[[2,3]]]
        │   │
        │   ├─→ FIRST recur(3)  [BASE: i>=n, pop → a=[2]]
        │   │
        │   └─→ SECOND recur(3)  [BASE: i>=n, pop → a=[]]
        │
        └─→ SECOND recur(2)  [add 3 to a → a=[3], v+=[[3]]]
            │
            ├─→ FIRST recur(3)  [BASE: i>=n, pop → a=[]]
            │
            └─→ SECOND recur(3)  [BASE: i>=n, pop → a=[]]


class Solution {
public:
    vector<int> a;
    vector<vector<int>> v;
    void recur(int i, vector<int>& nums, int n) {
        if (i == -1) {
            a.clear();
            v.push_back(a);

            recur((i + 1), nums, n);
            return;
        }
        if (i >= n) {
            a.pop_back();
            return;
        }
        a.push_back(nums[i]);
        v.push_back(a);

        recur((i + 1), nums, n);

        recur((i + 1), nums, n);
        return;
    }

    vector<vector<int>> subsets(vector<int>& nums) {
        int n = nums.size();
        recur(-1, nums, n);
        return v;
    }
};

